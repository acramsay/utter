[Unit]
Description=Utter push-to-talk transcription daemon
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/utter daemon
Restart=on-failure
RestartSec=2
# User-facing knobs (auto_paste, write_clipboard, filter_filler_words,
# PTT key) live in ~/.config/utter/config.toml.
Environment=RUST_LOG=info

[Install]
WantedBy=default.target
